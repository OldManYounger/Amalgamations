                                                                                   "minecraft:written_book_content":  {
                                                                                                                          "title":  {
                                                                                                                                        "raw":  "Rooms Upstairs"
                                                                                                                                    },
                                                                                                                          "author":  "Edwin Pike",
                                                                                                                          "pages":  [
                                                                                                                                        "{\"text\":\"Three guests again tonight. The miller snores, the shepherd talks in his sleep, and someone keeps taking the candle from the hall sconce.\\n\\nIf it happens once more, I am charging extra.\"}",
                                                                                                                                        "{\"text\":\"Note to self: patch the loose floorboard near the window before someone twists an ankle. Also buy more soap, and keep the good goblet downstairs where it belongs.\"}",
                                                                                                                                        "{\"text\":\"The lady in blue asked whether this place was haunted. I told her only by unpaid tabs. She laughed. Good sign.\"}"
                                                                                                                                    ]
                                                                                                                      }
                                                                               }
                                                            }
                                                        ]
                                      },
                                      {
                                          "type":  "minecraft:item",
