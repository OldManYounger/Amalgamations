                                          "weight":  2,
                                          "functions":  [
                                                            {
                                                                "function":  "minecraft:set_components",
                                                                "components":  {
                                                                                   "minecraft:written_book_content":  {
                                                                                                                          "title":  {
                                                                                                                                        "raw":  "A Guest\u0027s Diary"
                                                                                                                                    },
                                                                                                                          "author":  "Mira Holt",
                                                                                                                          "pages":  [
                                                                                                                                        "{\"text\":\"The Tudor Pub is warmer than it looks from the road. The bed creaks, but the stew is honest and the innkeep remembers names, which is more than most do.\"}",
                                                                                                                                        "{\"text\":\"I heard wagon bells past midnight and boots in the yard before dawn. Trade never really stops here. Even the walls seem tired.\"}"
                                                                                                                                    ]
                                                                                                                      }
                                                                               }
                                                            }
                                                        ]
                                      },
                                      {
