                                                                                   "minecraft:written_book_content":  {
                                                                                                                          "title":  {
                                                                                                                                        "raw":  "On Inns"
                                                                                                                                    },
                                                                                                                          "author":  "R. Thorne",
                                                                                                                          "pages":  [
                                                                                                                                        "{\"text\":\"Stayed at the Bearclaw Inn two nights prior. Cleaner floors, worse company.\"}",
                                                                                                                                        "{\"text\":\"The Tudor Pub lacks polish but has warmth. The fire is real, the bread is fresh.\"}",
                                                                                                                                        "{\"text\":\"Bearclaw has coin. Tudor has soul.\"}"
                                                                                                                                    ]
                                                                                                                      }
