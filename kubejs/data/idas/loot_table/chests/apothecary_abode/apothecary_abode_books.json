                                                                                                                                        "raw":  "Poison Notes"
                                                                                                                                    },
                                                                                                                          "author":  "Krell",
                                                                                                                          "pages":  [
                                                                                                                                        "{\"text\":\"Fermented spider eye turns a clear potion sour. The first sip is sweet, the second is trouble.\"}",
                                                                                                                                        "{\"text\":\"Weakness comes from a steady hand and a small dose. I tested on mice and a coop hen. The hen glared, but lived.\"}"
