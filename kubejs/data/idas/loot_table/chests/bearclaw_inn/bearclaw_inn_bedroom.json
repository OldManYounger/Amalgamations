                                      {
                                          "type":  "minecraft:item",
                                          "weight":  4,
                                          "name":  "minecraft:written_book",
                                          "functions":  [
                                                            {
                                                                "function":  "minecraft:set_components",
                                                                "components":  {
                                                                                   "minecraft:written_book_content":  {
                                                                                                                          "title":  {
                                                                                                                                        "raw":  "Bearclaw Night Notes"
                                                                                                                                    },
                                                                                                                          "author":  "Ivy",
                                                                                                                          "pages":  [
                                                                                                                                        "{\"text\":\"The bar below never really sleeps. The floor hums with singing, the rafters with stomping.\"}",
                                                                                                                                        "{\"text\":\"Upstairs, the quilts are soft and the windows hold the cold out. Cozy enough to make you forget the world is wide.\"}"
                                                                                                                                    ]
                                                                                                                      }
                                                                               }
                                                            }
                                                        ]
                                      },
                                      {
                                          "type":  "minecraft:item",
                                          "weight":  3,
                                          "name":  "minecraft:written_book",
                                          "functions":  [
                                                            {
                                                                "function":  "minecraft:set_components",
                                                                "components":  {
                                                                                   "minecraft:written_book_content":  {
                                                                                                                          "title":  {
                                                                                                                                        "raw":  "Ale and Snow"
                                                                                                                                    },
                                                                                                                          "author":  "Doran Pike",
                                                                                                                          "pages":  [
                                                                                                                                        "{\"text\":\"Met a cartographer who swore the mountain pass was haunted. He drank two mugs and drew a map that looked like a bear.\"}",
                                                                                                                                        "{\"text\":\"The innkeep laughed. The fire roared. The map was wrong, but the story was worth the coin.\"}"
                                                                                                                                    ]
                                                                                                                      }
                                                                               }
                                                            }
                                                        ]
                                      },
                                      {
                                          "type":  "minecraft:item",
                                          "weight":  3,
                                          "name":  "minecraft:written_book",
                                          "functions":  [
                                                            {
                                                                "function":  "minecraft:set_components",
                                                                "components":  {
                                                                                   "minecraft:written_book_content":  {
                                                                                                                          "title":  {
                                                                                                                                        "raw":  "Quiet Room, Loud Bar"
                                                                                                                                    },
                                                                                                                          "author":  "Mara",
                                                                                                                          "pages":  [
                                                                                                                                        "{\"text\":\"I only meant to rest a night. Stayed three. The bar noise is a kind of blanket if you let it be.\"}",
                                                                                                                                        "{\"text\":\"A hunter told me of a frozen cave with blue light. I told him I prefer warm bread and a door that latches.\"}"
                                                                                                                                    ]
                                                                                                                      }
                                                                               }
                                                            }
